# Environment setup - use separate DBs for dev vs production
#
# Development (npm run dev):  Use .env.development or .env.local
#   - See .env.development.example for dev Turso DB
#   - Omit TURSO_* to use local file:./database/cheffle.db
#
# Production (Vercel): Set vars in Project Settings → Environment Variables
#   - See .env.production.example for prod Turso DB
#
# Generate JWT_SECRET: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-in-production

OPENAI_API_KEY=sk-...

# SerpAPI - for AI recipe discovery (get a key at serpapi.com)
# SERPAPI_KEY=your-serpapi-key

# Turso database - use DIFFERENT databases for dev and production
# TURSO_DATABASE_URL=libsql://your-db-your-username.turso.io
# TURSO_AUTH_TOKEN=your-auth-token

# NEXT_PUBLIC_SITE_URL=https://your-domain.com
