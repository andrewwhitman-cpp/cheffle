# JWT secret for authentication (REQUIRED: set a secure random value for production builds)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-in-production

# OpenAI API key for recipe parsing (required for AI fallback when JSON-LD is not found)
OPENAI_API_KEY=sk-...

# Turso database (required for production / Vercel deployment)
# Local dev: omit these to use file:./database/cheffle.db
# Production: create a database at https://turso.tech and add:
# TURSO_DATABASE_URL=libsql://your-db-name-your-username.turso.io
# TURSO_AUTH_TOKEN=your-auth-token
