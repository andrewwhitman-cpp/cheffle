# Production environment - used when running `npm run build` and in Vercel
# For Vercel: set these in Project Settings → Environment Variables (Production)
# For local production build: copy to .env.production (gitignored)

# JWT secret - MUST be a secure random value (generate: openssl rand -base64 32)
JWT_SECRET=your-production-secret

# OpenAI API key
OPENAI_API_KEY=sk-...

# Turso PRODUCTION database - use a dedicated database for production
TURSO_DATABASE_URL=libsql://your-prod-db-your-username.turso.io
TURSO_AUTH_TOKEN=your-prod-auth-token

# Site URL for Open Graph / sharing (optional)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
