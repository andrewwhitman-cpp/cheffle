# Development environment - used when running `npm run dev`
# Copy to .env.development and fill in your dev Turso credentials
# Or use .env.local to override (takes precedence)

# JWT secret (generate: openssl rand -base64 32)
JWT_SECRET=your-dev-secret

# OpenAI API key
OPENAI_API_KEY=sk-...

# Turso DEV database - create a separate database at https://turso.tech for development
# This keeps dev data separate from production
TURSO_DATABASE_URL=libsql://your-dev-db-your-username.turso.io
TURSO_AUTH_TOKEN=your-dev-auth-token

# Optional: omit TURSO_* to use local file:./database/cheffle.db instead
